{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "mrjc-benin",
  "framework": "nextjs",

  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",

  "regions": ["cdg1", "fra1"],

  "env": {
    "NEXT_PUBLIC_SITE_URL": "@mrjc_site_url",
    "NEXT_PUBLIC_SITE_NAME": "@mrjc_site_name",
    "RESEND_API_KEY": "@resend_api_key",
    "CONTACT_EMAIL_TO": "@mrjc_contact_email",
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "ADMIN_EMAIL": "@admin_email",
    "ADMIN_PASSWORD_HASH": "@admin_password_hash",
    "NEXT_PUBLIC_RECAPTCHA_SITE_KEY": "@recaptcha_site_key",
    "RECAPTCHA_SECRET_KEY": "@recaptcha_secret_key"
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:jpg|jpeg|png|webp|avif|svg|ico|woff2|woff))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://www.googletagmanager.com https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://res.cloudinary.com https://via.placeholder.com https://picsum.photos https://*.openstreetmap.org; connect-src 'self' https://api.resend.com; frame-src https://www.google.com https://www.youtube.com; worker-src 'self' blob:;"
        }
      ]
    }
  ],

  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/don", "destination": "/work-with-us", "permanent": true },
    { "source": "/donate", "destination": "/work-with-us", "permanent": true },
    { "source": "/apropos", "destination": "/about", "permanent": true },
    { "source": "/nos-projets", "destination": "/projects", "permanent": true },
    { "source": "/actualites", "destination": "/news", "permanent": true }
  ],

  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap" },
    { "source": "/robots.txt", "destination": "/robots" }
  ],

  "crons": [
    {
      "path": "/api/cron/cleanup-visitors",
      "schedule": "0 2 * * *"
    }
  ],

  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  }
}
