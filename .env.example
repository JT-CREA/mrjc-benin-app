# =VOTRE_VALEUR_ICI
# MRJC-BÉNIN — Variables d'Environnement
# Fichier : .env.local  (NE PAS COMMITTER — ajouté dans .gitignore)
# =VOTRE_VALEUR_ICI

# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=VOTRE_VALEUR_ICI
NEXT_PUBLIC_APP_NAME=VOTRE_VALEUR_ICI
NODE_ENV=VOTRE_VALEUR_ICI

# ─── Base de données MongoDB Atlas ───────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=VOTRE_VALEUR_ICI
MONGODB_URI=VOTRE_VALEUR_ICI
MONGODB_DB_NAME=VOTRE_VALEUR_ICI

# ─── JWT / Authentification Admin ────────────────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=VOTRE_VALEUR_ICI
JWT_EXPIRATION=VOTRE_VALEUR_ICI
ADMIN_SESSION_DURATION=VOTRE_VALEUR_ICI

# ─── Resend (Emails transactionnels) ─────────────────────────────────────────
# Obtenir sur: https://resend.com/api-keys
RESEND_API_KEY=VOTRE_VALEUR_ICI
RESEND_FROM_EMAIL=VOTRE_VALEUR_ICI
RESEND_FROM_NAME=VOTRE_VALEUR_ICI

# ─── Destinataires emails ────────────────────────────────────────────────────
CONTACT_EMAIL_TO=VOTRE_VALEUR_ICI
CONTACT_EMAIL_CC=VOTRE_VALEUR_ICI
RECRUITMENT_EMAIL_TO=VOTRE_VALEUR_ICI

# ─── Brevo / Sendinblue (Newsletter) ─────────────────────────────────────────
# Obtenir sur: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=VOTRE_VALEUR_ICI
BREVO_LIST_ID=VOTRE_VALEUR_ICI
BREVO_WELCOME_TEMPLATE_ID=VOTRE_VALEUR_ICI

# ─── Revalidation ISR ────────────────────────────────────────────────────────
# Secret pour le webhook /api/revalidate
# Générer avec: openssl rand -hex 32
REVALIDATION_SECRET=VOTRE_VALEUR_ICI

# ─── Google Analytics / Tracking ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=VOTRE_VALEUR_ICI
NEXT_PUBLIC_MATOMO_URL=VOTRE_VALEUR_ICI
NEXT_PUBLIC_MATOMO_SITE_ID=VOTRE_VALEUR_ICI

# ─── reCAPTCHA v3 (Anti-spam formulaires) ────────────────────────────────────
# Obtenir sur: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=VOTRE_VALEUR_ICI
RECAPTCHA_SECRET_KEY=VOTRE_VALEUR_ICI
RECAPTCHA_MIN_SCORE=VOTRE_VALEUR_ICI

# ─── Cloudinary (Médias / Images) ────────────────────────────────────────────
# Optionnel — pour upload d'images admin
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=VOTRE_VALEUR_ICI
CLOUDINARY_API_KEY=VOTRE_VALEUR_ICI
CLOUDINARY_API_SECRET=VOTRE_VALEUR_ICI
CLOUDINARY_UPLOAD_PRESET=VOTRE_VALEUR_ICI

# ─── Réseaux Sociaux (URLs publiques) ────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_PAGE=VOTRE_VALEUR_ICI
NEXT_PUBLIC_TWITTER_HANDLE=VOTRE_VALEUR_ICI
NEXT_PUBLIC_LINKEDIN_PAGE=VOTRE_VALEUR_ICI
NEXT_PUBLIC_YOUTUBE_CHANNEL=VOTRE_VALEUR_ICI
NEXT_PUBLIC_INSTAGRAM_PAGE=VOTRE_VALEUR_ICI
NEXT_PUBLIC_WHATSAPP_NUMBER=VOTRE_VALEUR_ICI

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_NEWSLETTER=VOTRE_VALEUR_ICI
NEXT_PUBLIC_ENABLE_DONATE=VOTRE_VALEUR_ICI
NEXT_PUBLIC_ENABLE_MULTILANG=VOTRE_VALEUR_ICI
NEXT_PUBLIC_MAINTENANCE_MODE=VOTRE_VALEUR_ICI

# ─── Uptime / Monitoring (optionnel) ─────────────────────────────────────────
# BetterUptime, UptimeRobot, etc.
MONITORING_WEBHOOK_URL=VOTRE_VALEUR_ICI

# =VOTRE_VALEUR_ICI
# NOTES DE CONFIGURATION :
#
# 1. MongoDB Atlas:
#    - Créer un cluster gratuit (M0) sur https://cloud.mongodb.com
#    - Créer un utilisateur DB avec droits readWrite
#    - Whitelist 0.0.0.0/0 ou l'IP de Render.com
#    - Copier l'URI de connexion
#
# 2. Resend:
#    - Créer un compte sur https://resend.com
#    - Vérifier votre domaine mrjc-benin.org (DNS TXT record)
#    - Créer une API key avec droits d'envoi
#
# 3. Brevo:
#    - Créer un compte sur https://brevo.com
#    - Créer une liste "Newsletter MRJC-BÉNIN" et noter son ID
#    - Générer une API key dans Settings > API Keys
#
# 4. JWT_SECRET:
#    - Minimum 64 caractères aléatoires
#    - node -e "require('crypto').randomBytes(64).toString('hex')"
#
# 5. Déploiement Render.com:
#    - Ajouter chaque variable dans Dashboard > Environment > Environment Variables
#    - NE PAS committer ce fichier .env.local
# =VOTRE_VALEUR_ICI

# ─── Sécurité supplémentaire ──────────────────────────────────────────────────
# Clé AES-256 pour chiffrement données sensibles en DB
# Générer: openssl rand -hex 32
ENCRYPTION_KEY=VOTRE_VALEUR_ICI

# ─── Admin credentials ────────────────────────────────────────────────────────
ADMIN_EMAIL=VOTRE_VALEUR_ICI
# Hash bcrypt du mot de passe (générer: node -e "require('bcryptjs').hash('VotreMotDePasse',12).then(console.log)")
ADMIN_PASSWORD_HASH=VOTRE_VALEUR_ICI

# ─── Limites upload ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=VOTRE_VALEUR_ICI
ALLOWED_FILE_TYPES=VOTRE_VALEUR_ICI

# ─── Sentry (monitoring erreurs — optionnel) ──────────────────────────────────
# SENTRY_DSN=VOTRE_VALEUR_ICI
# NEXT_PUBLIC_SENTRY_DSN=VOTRE_VALEUR_ICI
